#!/usr/bin/env bun
import { defineCommand, runMain } from "citty";
import { intro, outro, spinner, select, text, confirm } from "@clack/prompts";
import { spawn } from "child_process";
import { resolve, dirname } from "path";
import { fileURLToPath } from "url";
import fs from "fs/promises";

const __dirname = dirname(fileURLToPath(import.meta.url));
const extensionPath = resolve(__dirname, "../src/extension.ts");

const main = defineCommand({
  meta: {
    name: "hatchling",
    version: "0.1.0",
    description: "An autonomous AI agent that learns, mutates, and evolves",
  },
  subCommands: {
    init: defineCommand({
      meta: {
        description: "Initialize a new Hatchling organism (onboarding)",
      },
      async run() {
        intro("🥚 Hatchling Initialization");

        const s = spinner();
        s.start("Checking environment...");
        
        // Check if already initialized
        const selfDir = resolve(process.cwd(), ".self");
        try {
          await fs.access(selfDir);
          s.stop("Already initialized");
          const shouldReinit = await confirm({
            message: "Hatchling is already initialized. Re-initialize?",
            initialValue: false,
          });
          if (!shouldReinit) {
            outro("Initialization cancelled");
            process.exit(0);
          }
        } catch {
          // Not initialized yet, continue
        }
        s.stop("Environment ready");

        // Step 1: Select Provider
        const provider = await select({
          message: "Select AI provider:",
          options: [
            { value: "anthropic", label: "Anthropic (Claude)" },
            { value: "openai", label: "OpenAI (GPT)" },
            { value: "ollama", label: "Ollama (Local)" },
            { value: "google", label: "Google (Gemini)" },
          ],
        });

        if (typeof provider === "symbol") {
          outro("Initialization cancelled");
          process.exit(0);
        }

        // Step 2: Select Model
        const modelOptions: Record<string, any[]> = {
          anthropic: [
            { value: "claude-3-5-sonnet-20241022", label: "Claude 3.5 Sonnet (Recommended)" },
            { value: "claude-3-opus-20240229", label: "Claude 3 Opus" },
            { value: "claude-3-haiku-20240307", label: "Claude 3 Haiku (Fast)" },
          ],
          openai: [
            { value: "gpt-4-turbo", label: "GPT-4 Turbo (Recommended)" },
            { value: "gpt-4", label: "GPT-4" },
            { value: "gpt-3.5-turbo", label: "GPT-3.5 Turbo (Fast)" },
          ],
          ollama: [
            { value: "qwen2.5-coder:7b", label: "Qwen 2.5 Coder 7B (Recommended)" },
            { value: "llama3.1:8b", label: "Llama 3.1 8B" },
            { value: "deepseek-r1:1.5b", label: "DeepSeek R1 1.5B (Fast)" },
          ],
          google: [
            { value: "gemini-1.5-pro", label: "Gemini 1.5 Pro (Recommended)" },
            { value: "gemini-1.5-flash", label: "Gemini 1.5 Flash (Fast)" },
          ],
        };

        const model = await select({
          message: "Select model:",
          options: modelOptions[provider as string] || [],
        });

        if (typeof model === "symbol") {
          outro("Initialization cancelled");
          process.exit(0);
        }

        // Step 3: Self-discovery conversation (includes name discovery)
        s.start("Starting self-discovery conversation...");
        
        const { runSelfDiscovery } = await import("../src/system/onboard.js");
        const agentName = await runSelfDiscovery(
          {
            provider: provider as string,
            model: model as string,
          },
          process.cwd()
        );
        
        s.stop("Identity created");
        
        outro(`✨ Initialization complete! ${agentName} is ready to hatch.

Run 'hatchling start' to begin your journey.`);
      },
    }),

    start: defineCommand({
      meta: {
        description: "Start Hatchling with pi-coding-agent",
      },
      async run({ args }) {
        intro("🐣 Starting Hatchling");

        // Check if initialized
        const selfDir = resolve(process.cwd(), ".self");
        try {
          await fs.access(selfDir);
        } catch {
          outro("❌ Not initialized. Run 'hatchling init' first.");
          process.exit(1);
        }

        // Launch pi with extension
        const piArgs = ["pi", "--extension", extensionPath, ...args._];
        const child = spawn("bun", piArgs, {
          stdio: "inherit",
          cwd: process.cwd(),
        });

        child.on("exit", (code) => {
          process.exit(code || 0);
        });
      },
    }),

    vitals: defineCommand({
      meta: {
        description: "Show system health and metrics",
      },
      async run() {
        intro("💓 Hatchling Vitals");
        
        const s = spinner();
        s.start("Reading vitals...");
        
        // Import vitals module
        const { getVitals } = await import("../src/system/vitals.js");
        const vitals = await getVitals(process.cwd());
        
        s.stop("Vitals loaded");
        
        console.log("\n📊 System Status:");
        console.log(`  Territory: ${vitals.territory}`);
        console.log(`  Commits: ${vitals.commits}`);
        console.log(`  Energy: ${vitals.energy}%`);
        console.log(`  Curiosity: ${vitals.curiosity}`);
        console.log(`  Daemon: ${vitals.daemonStatus}`);
        
        outro("Health check complete");
      },
    }),
  },

  async run({ args }) {
    // Default: show help
    if (args._.length === 0) {
      intro("🥚 Hatchling - Autonomous AI Agent");
      console.log("\nAvailable commands:");
      console.log("  init    - Initialize a new Hatchling organism");
      console.log("  start   - Start Hatchling with pi-coding-agent");
      console.log("  vitals  - Show system health and metrics");
      console.log("\nRun 'hatchling <command> --help' for more information");
      outro("Ready to evolve");
    }
  },
});

runMain(main);
